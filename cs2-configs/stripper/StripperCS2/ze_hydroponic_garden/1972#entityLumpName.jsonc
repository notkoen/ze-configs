{
  "modify": [
    // Offset item height after AG2 update
    {
      "match": {
        "targetname": "[PR#]zombie_gravity_eff"
      },
      "replace": {
        "origin": "27.500000 0.000000 4.000000"
      }
    },
    {
      "match": {
        "targetname": "[PR#]zombie_gravity_particle"
      },
      "replace": {
        "origin": "0.000000 -0.500000 -20.000000"
      }
    }
  ]
}
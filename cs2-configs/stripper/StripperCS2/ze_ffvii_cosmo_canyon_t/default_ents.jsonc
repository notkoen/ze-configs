{
	"modify": [
		// Add stripper credit
		{
			"match": {
				"classname": "logic_auto"
			},
			"insert": {
				"io": [
					{
						"outputname": "OnMapSpawn",
						"targetname": "[PR#]cmd",
						"inputname": "Command",
						"overrideparam": "say *** Door fix, invis model, item height, and knife strip fixed by koen ***",
						"delay": 5
					}
				]
			}
		},
		// Fix cosmo doors rotating wrong direction
		{
			"match": {
				"classname": "func_door_rotating"
			},
			"replace": {
				"spawnflags": "16"
			}
		},
		// Fix incorrect rendermode
		{
			"match": {
				"classname": "prop_dynamic",
				"targetname": "[PR#]Jenova_Model"
			},
			"replace": {
				"rendermode": "0"
			}
		},
		{
			"match": {
				"classname": "prop_dynamic",
				"targetname": "[PR#]Genesis_Model"
			},
			"replace": {
				"rendermode": "0"
			}
		},
		{
			"match": {
				"classname": "prop_dynamic",
				"targetname": "[PR#]Shinra_Ifrit"
			},
			"replace": {
				"rendermode": "0"
			}
		},
		// Fix weapon strip
		{
			"match": {
				"classname": "player_weaponstrip",
				"targetname": "[PR#]Map_Stripper"
			},
			"replace": {
				"classname": "game_player_equip"
			},
			"insert": {
				"spawnflags": "3"
			}
		}
	],
	"filter": [
		// Remove old strip entities
		{
			"classname": "point_entity_finder",
			"targetname": "[PR#]Knife_Strip"
		},
		{
			"classname": "logic_relay",
			"targetname": "[PR#]Strip_Knife"
		},
		{
			"classname": "point_template",
			"targetname": "[PR#]Knife_Stripper_Template"
		},
		{
			"classname": "point_teleport",
			"targetname": "[PR#]Knife_Stripper_Teleport"
		}
	]
}
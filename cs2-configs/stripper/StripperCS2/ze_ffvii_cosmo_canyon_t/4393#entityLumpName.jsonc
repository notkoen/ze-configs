{
	"modify": [
		// Offset item position after AG2 update
		{
			"match": {
				"targetname": "[PR#]Item_Z_Confuse_button"
			},
			"replace": {
				"origin": "23.000000 0.000000 24.000000"
			}
		},
		{
			"match": {
				"targetname": "[PR#]Item_Z_Confuse_eff"
			},
			"replace": {
				"origin": "23.000000 0.000000 4.000000"
			}
		},
		{
			"match": {
				"targetname": "[PR#]Item_Z_Confuse_particle"
			},
			"replace": {
				"origin": "0.000000 0.000000 -32.000000"
			}
		},
		// Fix weapon strip
		{
			"match": {
				"targetname": "[PR#]Item_Z_Confuse_Stripper"
			},
			"delete": {
				"io": [
					{
						"outputname": "OnStartTouch",
						"targetname": "[PR#]Strip_Knife",
						"inputname": "Trigger",
						"overrideparam": "",
						"delay": 0,
						"timestofire": -1
					}
				]
			},
			"insert": {
				"io": [
					{
						"outputname": "OnTrigger",
						"targetname": "[PR#]Map_Stripper",
						"inputname": "Use",
						"overrideparam": "",
						"delay": 0.0,
						"timestofire": 1
					},
					{
						"outputname": "OnTrigger",
						"targetname": "!self",
						"inputname": "Kill",
						"overrideparam": "",
						"delay": 0.05,
						"timestofire": 1
					}
				]
			}
		}
	]
}
{
  "modify": [
    // Add stripper credit
    {
      "match": {
        "classname": "logic_auto"
      },
      "insert": {
        "io": [
          {
            "outputname": "OnMapSpawn",
            "targetname": "[PR#]CONSOLE",
            "inputname": "Command",
            "overrideparam": "say *** 双开门及血针无法恢复超过100血由koen修复 ***",
            "delay": 5
          }
        ]
      }
    },
    // Fix incorrect door direction
    {
      "match": {
        "classname": "func_door_rotating"
      },
      "replace": {
        "spawnflags": "48"
      }
    }
  ]
}
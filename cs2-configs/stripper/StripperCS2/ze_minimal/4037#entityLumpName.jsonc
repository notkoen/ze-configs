{
  "modify": [
    // Offset item height after AG2 update
    {
      "match": {
        "targetname": "[PR#]freezer_maker"
      },
      "replace": {
        "origin": "18.000000 0.000000 -64.000000"
      }
    },
    {
      "match": {
        "targetname": "[PR#]freezer_eff"
      },
      "replace": {
        "origin": "21.000000 -2.000000 -24.000000"
      }
    }
  ]
}
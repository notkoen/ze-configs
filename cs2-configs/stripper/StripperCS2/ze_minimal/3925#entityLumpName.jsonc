{
  "modify": [
    // Offset item height after AG2 update
    {
      "match": {
        "targetname": "[PR#]push_maker"
      },
      "replace": {
        "origin": "154.000000 -2.000000 -48.000000"
      }
    },
    {
      "match": {
        "targetname": "[PR#]push_eff"
      },
      "replace": {
        "origin": "34.000000 -1.000000 -24.000000"
      }
    }
  ]
}
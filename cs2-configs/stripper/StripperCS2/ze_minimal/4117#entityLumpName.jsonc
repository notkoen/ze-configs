{
  "modify": [
    // OFfset item height after AG2 update
    {
      "match": {
        "targetname": "[PR#]ammo_eff"
      },
      "replace": {
        "origin": "15.000000 -2.000000 -24.000000"
      }
    },
    {
      "match": {
        "targetname": "[PR#]ammo_particle"
      },
      "replace": {
        "origin": "15.000000 -2.000000 -64.000000"
      }
    }
  ]
}
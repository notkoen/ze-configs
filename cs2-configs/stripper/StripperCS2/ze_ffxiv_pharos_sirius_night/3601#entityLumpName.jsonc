          {
            "outputname": "OnTrigger",
            "targetname": "[PR#]server_command",
            "inputname": "Command",
            "overrideparam": "say < Rock Burst >",
            "delay": 0,
            "timestofire": -1
          }
        ]
      }
    },
    {
      "match": {
        "targetname": "[PR#]relay_ladylilith_anima_ingest"
      },
      "delete": {
        "io": [
          {
            "overrideparam": "/< Anima Ingest >/"
          }

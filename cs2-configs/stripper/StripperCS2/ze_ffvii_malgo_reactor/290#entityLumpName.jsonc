{
  "modify": [
    // Rework boss health to use counter instead
    {
      "match": {
        "targetname": "[PR#]Sephiroth_Final_Breakable"
      },
      "insert": {
        "io": [
          {
            "outputname": "OnHealthChanged",
            "targetname": "[PR#]Final_Sephiroth_Counter",

{
    "modify": [
        // Add stripper credit
        {
            "match": {
                "classname": "logic_auto"
            },
            "insert": {
                "io": [
                    {
                        "outputname": "OnMapSpawn",
                        "targetname": "[PR#]server",
                        "inputname": "Command",
                        "overrideparam": "say *** 双开门，未隐形弹幕模型，及神器高度由 koen 修复 ***",
                        "delay": 5,
                        "timestofire": 1
                    }
                ]
            }
        },
        // Fix incorrect door direction
        {
            "match": {
                "targetname": "[PR#]nut_door11_1"
            },
            "replace": {
                "spawnflags": "4112"
            }
        },
        {
            "match": {
                "targetname": "[PR#]nut_door12_1"
            },
            "replace": {
                "spawnflags": "4112"
            }
        },
        {
            "match": {
                "targetname": "[PR#]nut_door12_2"
            },
            "replace": {
                "spawnflags": "4112"
            }
        },
        {
            "match": {
                "targetname": "[PR#]nut_door11_2"
            },
            "replace": {
                "spawnflags": "4112"
            }
        }
    ]
}
{
  "modify": [
    // Buff zombie item health
    {
      "match": {
        "classname": "weapon_knife",
        "targetname": "[PR#]Weapon_zm_gravity"
      },
      "delete": {
        "io": [
          {
            "outputname": "OnPlayerPickup",
            "targetname": "!activator",
            "inputname": "KeyValue",
            "overrideparam": "health 50000",
            "delay": 0,
            "timestofire": 1
          }
        ]
      },
      "insert": {
        "io": [
          {
            "outputname": "OnPlayerPickup",
            "targetname": "!activator",
            "inputname": "KeyValue",
            "overrideparam": "health 150000",
            "delay": 0,
            "timestofire": 1
          },
          {
            "outputname": "OnPlayerPickup",
            "targetname": "!activator",
            "inputname": "KeyValue",
            "overrideparam": "max_health 150000",
            "delay": 0,
            "timestofire": 1
          }
        ]
      }
    }
  ]
}
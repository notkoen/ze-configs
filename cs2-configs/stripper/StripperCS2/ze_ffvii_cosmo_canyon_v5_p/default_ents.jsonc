      },
      "insert": {
        "template04": "[PR#]Item_Electro_Button"
      }
    },
    {
      "match": {
        "targetname": "[PR#]Item_Fire_Temp"
      },
      "insert": {
        "template04": "[PR#]Item_Fire_Button"
      }
    },
    {
      "match": {

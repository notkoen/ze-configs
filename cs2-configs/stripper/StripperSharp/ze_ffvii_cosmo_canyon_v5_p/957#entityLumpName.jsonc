{
  "modify": [
    // Change c4 item to knife item and add filter
    {
      "match": {
        "classname": "weapon_c4"
      },
      "insert": {
        "classname": "weapon_knife",
        "connections": [
          {
            "output": "OnPlayerPickup",
            "target": "!activator",
            "input": "AddContext",
            "param": "zitem_pickup:1",
            "delay": 0,
            "limit": 1
          }
        ]
      }
    }
  ],
  "add": [
    // Add strip trigger to the knife
    {
      "classname": "trigger_multiple",
      "targetname": "[PR#]ZombieFireStripTrigger",
      "origin": "-5.000000 0.000000 -3.000000",
      "angles": "-0.000000 0.000000 0.000000",
      "scales": "1.000000 1.000000 1.000000",
      "spawnflags": "4097",
      "filtername": "[PR#]Filter_Z_Items_Pickup",
      "model": "maps/ze_ffvii_cosmo_canyon_v5_p/entities/cactuszm_z_stripknife_53121.vmdl",
      "startdisabled": "False",
      "wait": "1",
      "uselocaloffset": "False",
      "_template_lump_ent_index": "7",
      "connections": [
        {
          "output": "OnStartTouch",
          "target": "[PR#]script_cosmo",
          "input": "RunScriptInput",
          "param": "StripKnife",
          "delay": 0,
          "limit": 1
        },
        {
          "output": "OnStartTouch",
          "target": "!self",
          "input": "Kill",
          "param": "",
          "delay": 0,
          "limit": 1
        }
      ]
    }
  ]
}
{
  "modify": [
    // Offset item height after AG2 update
    {
      "match": {
        "targetname": "[PR#]zgravity_eff"
      },
      "insert": {
        "origin": "27.000000 0.000000 -8.000000"
      }
    },
    {
      "match": {
        "targetname": "[PR#]zgravity_particle"
      },
      "insert": {
        "origin": "0.000000 -0.500000 32.000000"
      }
    }
  ]
}